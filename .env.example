# Copy this file to `.env` and fill in ONE provider's key, then add `--real` to any command.
# Without a key, everything runs in mock mode (deterministic, offline, free).
# `.env` is gitignored — never commit real keys.

# ---- Option A: Groq (free, recommended) ---------------------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
KINTSUGI_GROQ_PLAN_MODEL=llama-3.1-8b-instant
KINTSUGI_GROQ_DRAFT_MODEL=llama-3.3-70b-versatile
KINTSUGI_GROQ_REPAIR_MODEL=llama-3.3-70b-versatile
KINTSUGI_GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# ---- Option B: Anthropic (optional) -------------------------------------------------
# If both keys are set, Groq wins. Leave blank to use Groq.
ANTHROPIC_API_KEY=
KINTSUGI_PLAN_MODEL=claude-haiku-4-5-20251001
KINTSUGI_DRAFT_MODEL=claude-haiku-4-5-20251001
KINTSUGI_REPAIR_MODEL=claude-sonnet-5
KINTSUGI_JUDGE_MODEL=claude-haiku-4-5-20251001
