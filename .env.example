# Copy to .env and fill in to run against real models.
# Without this, everything runs in --mock mode (deterministic, offline, no cost).
ANTHROPIC_API_KEY=

# Model routing (defaults shown). Draft/plan cheap, repair strong.
KINTSUGI_PLAN_MODEL=claude-haiku-4-5-20251001
KINTSUGI_DRAFT_MODEL=claude-haiku-4-5-20251001
KINTSUGI_REPAIR_MODEL=claude-sonnet-5
KINTSUGI_JUDGE_MODEL=claude-haiku-4-5-20251001
